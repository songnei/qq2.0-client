import router from '@ohos.router'
import { login, getToken } from './HttpRequest'
import { promptAction } from '@kit.ArkUI'
import { connect as connectWs } from './WsManager'

@Entry
@Component
struct LoginPage {
  @State account: string = ''
  @State password: string = ''
  @State showPassword: boolean = false
  @State isLoading: boolean = false

  aboutToAppear(): void {
    const token = getToken()
    if (token) {
      connectWs()
      router.replaceUrl({ url: 'pages/MainPage' })
    }
  }

  async handleLogin(): Promise<void> {
    if (!this.account) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘиҙҰеҸ·' })
      return
    }
    if (!this.password) {
      promptAction.showToast({ message: 'иҜ·иҫ“е…ҘеҜҶз Ғ' })
      return
    }

    this.isLoading = true
    try {
      await login(this.account, this.password)
      connectWs()
      promptAction.showToast({ message: 'зҷ»еҪ•жҲҗеҠҹ' })
      router.replaceUrl({ url: 'pages/MainPage' })
    } catch (err) {
      const error = err as Error
      promptAction.showToast({ message: error.message || 'зҷ»еҪ•еӨұиҙҘ' })
    } finally {
      this.isLoading = false
    }
  }

  build() {
    Column() {
      Stack({ alignContent: Alignment.TopStart }) {
        Column() {
          Text('зҷ»еҪ•')
            .fontSize(24)
            .fontWeight(FontWeight.Medium)
            .fontColor('#333333')
            .margin({ top: 60 })
        }
        .width('100%')
        .height('100%')

        Text('вҖ№')
          .fontSize(24)
          .margin({ top: 60, left: 16 })
          .onClick(() => {
            router.back()
          })
      }
      .width('100%')
      .height(120)

      Column({ space: 24 }) {
        Column({ space: 16 }) {
          Column() {
            TextInput({ placeholder: 'QQеҸ·/жүӢжңәеҸ·/йӮ®з®ұ', text: this.account })
              .fontSize(16)
              .onChange((value: string) => {
                this.account = value
              })
            Divider()
              .color('#E5E5E5')
          }
          .width('100%')
          .padding({ bottom: 12 })

          Column() {
            Row() {
              TextInput({ placeholder: 'иҜ·иҫ“е…ҘеҜҶз Ғ', text: this.password })
                .type(this.showPassword ? InputType.Normal : InputType.Password)
                .fontSize(16)
                .layoutWeight(1)
                .onChange((value: string) => {
                  this.password = value
                })

              Text(this.showPassword ? 'рҹ‘ҒпёҸ' : 'рҹ‘ҒпёҸвҖҚрҹ—ЁпёҸ')
                .fontSize(20)
                .onClick(() => {
                  this.showPassword = !this.showPassword
                })
            }
            .width('100%')
            Divider()
              .color('#E5E5E5')
          }
          .width('100%')
          .padding({ bottom: 12 })
        }
        .width('100%')
        .padding(24)

        Button(this.isLoading ? 'зҷ»еҪ•дёӯ...' : 'зҷ»еҪ•')
          .width('90%')
          .height(48)
          .fontSize(16)
          .backgroundColor('#12B7F5')
          .borderRadius(24)
          .enabled(!this.isLoading)
          .onClick(() => {
            this.handleLogin()
          })

        Row() {
          Text('еҝҳи®°еҜҶз Ғпјҹ')
            .fontSize(14)
            .fontColor('#12B7F5')
          Blank()
          Text('ж–°з”ЁжҲ·жіЁеҶҢ')
            .fontSize(14)
            .fontColor('#12B7F5')
            .onClick(() => {
              router.pushUrl({ url: 'pages/RegisterPage' })
            })
        }
        .width('90%')
        .padding({ top: 16 })
      }
      .width('100%')
      .layoutWeight(1)

      Column({ space: 16 }) {
        Text('зҷ»еҪ•еҚід»ЈиЎЁеҗҢж„Ҹ')
          .fontSize(12)
          .fontColor('#999999')

        Row({ space: 8 }) {
          Text('гҖҠз”ЁжҲ·еҚҸи®®гҖӢ')
            .fontSize(12)
            .fontColor('#12B7F5')
          Text('гҖҠйҡҗз§Ғж”ҝзӯ–гҖӢ')
            .fontSize(12)
            .fontColor('#12B7F5')
        }
      }
      .width('100%')
      .padding({ bottom: 40 })
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#FFFFFF')
  }
}
